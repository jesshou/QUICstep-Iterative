theory QUICstep_ClientInit
begin

builtins: diffie-hellman, symmetric-encryption, hashing

functions:
    /* Key derivation */
    HKDF_Extract/2,
    HKDF_Expand/3,
    initial_secret/2,
    client_initial_key/1,
    server_initial_key/1,
    /* Connection ID */
    gen_cid/1

/* ─────────────────────────────────────────────
   PROCESS: Client Initialization
   Generates:
     - (skC, pkC)          asymmetric keypair
     - DCID                Destination Connection ID
     - client_initial_key  AEAD key for client Initial packets
     - server_initial_key  AEAD key for server Initial packets
   ───────────────────────────────────────────── */
let ClientInit =
    /* 1. Generate client long-term DH keypair */
    new skC;
    let pkC = 'g'^skC in

    /* 2. Generate Destination Connection ID (DCID)
          RFC 9000 §7.2: chosen by client, at least 8 bytes of randomness */
    new dcid_rand;
    let DCID = gen_cid(dcid_rand) in

    /* 3. Derive the QUIC Initial secret
          initial_secret = HKDF-Extract(QUIC_VERSION_SALT, DCID)
          (salt is a well-known constant per QUIC version) */
    let version_salt = 'quic_v1_salt' in          /* public constant */
    let init_secret  = HKDF_Extract(version_salt, DCID) in

    /* 4. Derive per-direction Initial keys
          client key = HKDF-Expand(init_secret, "client in", key_len)
          server key = HKDF-Expand(init_secret, "server in", key_len) */
    let ck = client_initial_key(
                 HKDF_Expand(init_secret, 'client_in', '16')) in
    let sk = server_initial_key(
                 HKDF_Expand(init_secret, 'server_in', '16')) in

    /* 5. Publish the client's public key (sent in ClientHello) */
    out(pkC);

    /* 6. Record the established state for downstream processes
          (DCID is sent in the clear in Initial packets;
           Initial keys are known to the adversary per RFC 9001 §5.2) */
    out(DCID);

    /* Derived Initial keys are intentionally NOT published —
       they are passed internally to the handshake process.
       (Tamarin models this via state facts below.)              */

    event ClientInitDone(pkC, DCID, ck, sk);

    /* Pass state to the handshake process */
    insert <'ClientState', pkC>,
           <skC, DCID, ck, sk>

/* ─────────────────────────────────────────────
   MAIN PROCESS
   ───────────────────────────────────────────── */
process:
    !ClientInit
  
/* Master witness — all four outputs were produced in one run */
lemma client_init_done:
exists-trace
  "Ex pkC dcid ck sk #i. ClientInitDone(pkC, dcid, ck, sk) @ #i"

end