//   "Ex #i #j #k #l #m #n #p.
//      ClientHelloSent('vpn') @ #i &
//      ServerHelloSent('vpn') @ #j &
//      HandshakeFinishedFirst('vpn') @ #k &
//      HandshakeFinishedConfirmed('vpn') @ #l &
//      HandshakeConfirmationSent('quic') @ #m &
//      QUICstepComplete('client') @ #n &
//      QUICstepComplete('server') @ #p &
//      #i < #j & #j < #k & #k < #l & #l < #m & #m < #n & #n < #p
//   "

end