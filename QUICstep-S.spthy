theory QUICStep

begin

builtins: diffie-hellman, hashing, symmetric-encryption
functions: h1/1

let C() =
    new dcid;
    new ~eskC;
    let pkC = 'g'^~eskC in
    let initial_secret = h1(<'quic_initial_salt', dcid>) in
    let client_initial_secret = h1(<initial_secret, 'client'>) in
    let server_initial_secret = h1(<initial_secret, 'server'>) in
    0

let S() =
    0

process:
  ( !C() | !S() )

// lemma QUICstep:
